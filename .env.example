AUTH_SESSION_SECRET=zmente-tento-retezec-na-vlastni-tajny-klic

# Databaze pro CMS / admin rozhrani (na Vercelu pouzijte DATABASE_URL nebo POSTGRES_URL z Neon/Vercel Postgres)
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# POSTGRES_URL=postgresql://user:password@host/database?sslmode=require

# ── E-mail pro kontaktní / oceňovací formulář ─────────────────────────────
# Bez nastavení alespoň jedné varianty vrací /api/contact chybu 503
# a formuláře na webu zobrazí "Formulář je dočasně mimo provoz".
# Po změně proměnných na Vercelu je nutný redeploy!

# Varianta A — Resend (doporučeno): https://resend.com → API Keys
# POZOR: bez ověřené domény posílá Resend z onboarding@resend.dev a doručí
# POUZE na e-mail vlastníka Resend účtu. Pro doručování na info@mikaauto.cz
# buď založte Resend účet na tento e-mail, nebo ověřte doménu mikaauto.cz
# v Resendu a nastavte RESEND_FROM.
# RESEND_API_KEY=
# RESEND_FROM="Mika Auto Web <web@mikaauto.cz>"

# Varianta B — SMTP (údaje od poskytovatele e-mailu, kde běží info@mikaauto.cz)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Příjemce zpráv z formulářů (výchozí: info@mikaauto.cz)
# KONTAKT_EMAIL=info@mikaauto.cz
